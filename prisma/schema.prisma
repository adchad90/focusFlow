datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String    @id @default(uuid())
  discordId       String?   @unique
  discordUsername String    @unique
  webhookUrl      String?
  interests       String
  noise           String
  frequency       String    @default("daily")
  lastSentAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profiles        Profile[]
  sources         Source[]
  curations       Curation[]
  feedbacks       Feedback[]
}

model Profile {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String   // "twitter", "linkedin", "leetcode", "github", etc.
  handle    String   // Username/handle on the platform
  url       String
  createdAt DateTime @default(now())

  @@unique([userId, platform])
}

model Source {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "subreddit", "rss"
  value     String   // e.g. "typescript" or "https://news.ycombinator.com/rss"
  createdAt DateTime @default(now())

  @@unique([userId, type, value])
}

model Curation {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  url       String
  source    String     // e.g. "r/typescript"
  summary   String
  priority  String     // "HIGH" | "MEDIUM"
  createdAt DateTime   @default(now())
  feedback  Feedback?
}

model Feedback {
  id         String   @id @default(uuid())
  curationId String   @unique
  curation   Curation @relation(fields: [curationId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int      // Numerical score 0 to 10
  createdAt  DateTime @default(now())
}
