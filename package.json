{
  "name": "focusflow",
  "version": "1.0.0",
  "description": "MCP-Powered Personal Information Curation Engine",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --no-warnings=ExperimentalWarning --loader ts-node/esm src/index.ts",
    "test-digest": "node --no-warnings=ExperimentalWarning --loader ts-node/esm src/index.ts --test",
    "web": "node --no-warnings=ExperimentalWarning --loader ts-node/esm src/index.ts --web",
    "web:daemon": "node --no-warnings=ExperimentalWarning --loader ts-node/esm src/index.ts --web --daemon",
    "web:dev": "vite --config src/web/vite.config.ts",
    "web:build": "vite build --config src/web/vite.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma db push"
  },
  "prisma": {
    "seed": "node --no-warnings=ExperimentalWarning --loader ts-node/esm prisma/seed.ts"
  },
  "dependencies": {
    "@fetchlayer/reddit": "^0.1.1",
    "@google/genai": "^2.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.16.1",
    "axios": "^1.7.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "prisma": "^5.16.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2",
    "vite": "^8.1.5"
  }
}
